generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./hireeasy.db"
}

model Job {
  id              String       @id @default(uuid())
  title           String
  department      String?
  description     String?
  jdFilePath      String?
  sheetUrl        String?
  status          String       @default("active")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  technicalSkills  Skill[]     @relation("TechnicalSkills")
  nonTechSkills    Skill[]     @relation("NonTechSkills")
  behavioralSkills Skill[]     @relation("BehavioralSkills")
  candidates       Candidate[]
  interviewRounds  InterviewRound[]
  questionBank     QuestionBank[]
}

model Skill {
  id        String  @id @default(uuid())
  name      String
  weight    Int     @default(50)
  type      String

  jobTech       Job?   @relation("TechnicalSkills", fields: [jobTechId], references: [id])
  jobTechId     String?
  jobNonTech    Job?   @relation("NonTechSkills", fields: [jobNonTechId], references: [id])
  jobNonTechId  String?
  jobBehavior   Job?   @relation("BehavioralSkills", fields: [jobBehaviorId], references: [id])
  jobBehaviorId String?
}

model Candidate {
  id              String    @id @default(uuid())
  jobId           String
  name            String
  email           String?
  phone           String?
  resumeUrl       String?
  resumeLocalPath String?
  responses       String?
  aiDetectionScore Float?
  l1Score         Float?
  l2Score         Float?
  finalScore      Float?
  status          String    @default("applied")
  shortlistLevel  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviews      Interview[]
  feedback        Feedback[]
}

model InterviewRound {
  id              String      @id @default(uuid())
  jobId           String
  roundNumber     Int
  type            String
  scheduledDate   DateTime?
  meetingLength   Int?
  interviewerEmail String?
  useAppInterview  Boolean    @default(false)
  status          String     @default("pending")
  createdAt       DateTime   @default(now())

  job             Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  interviews      Interview[]
  questions       InterviewQuestion[]
}

model InterviewQuestion {
  id              String         @id @default(uuid())
  roundId         String
  questionText    String
  orderIndex      Int
  isSample        Boolean        @default(false)

  round           InterviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model Interview {
  id              String         @id @default(uuid())
  candidateId     String
  roundId         String
  uniqueToken     String         @unique
  status          String         @default("pending")
  overallScore    Float?
  confidenceScore Float?
  scheduledAt     DateTime?
  completedAt     DateTime?
  calendarEventId String?
  meetingLink     String?

  candidate       Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  round           InterviewRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  responses       InterviewResponse[]
  feedback        Feedback[]
}

model InterviewResponse {
  id            String    @id @default(uuid())
  interviewId   String
  questionText  String
  audioUrl      String?
  transcript    String?
  score         Float?
  createdAt     DateTime  @default(now())

  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Feedback {
  id            String    @id @default(uuid())
  interviewId   String
  candidateId   String
  criteria      String
  rating        Int
  notes         String?
  createdAt     DateTime  @default(now())

  interview     Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidate     Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model QuestionBank {
  id            String    @id @default(uuid())
  jobId         String
  category      String?
  questionText  String
  createdAt     DateTime  @default(now())

  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model AppSettings {
  id              String  @id @default("singleton")
  openaiKey       String?
  anthropicKey    String?
  geminiKey       String?
  deepgramKey     String?
  aiDetectionKey  String?
  preferredLlm    String  @default("openai")
  aiDetectionProvider String @default("sapling")
  googleClientId  String?
  googleClientSecret String?
  authenticatedEmail String?
  googleTokens    String?
  interviewAppUrl String?
}
